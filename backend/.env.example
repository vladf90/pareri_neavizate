# Server Configuration
# Copy this file to .env and adjust values

# Server host - use 0.0.0.0 for LAN access
HOST=0.0.0.0
PORT=3001

# SportMonks API Token (required)
SPORTMONKS_TOKEN=your_token_here

# TipeeStream API Key (optional)
TIPEESTREAM_API_KEY=

# Polling intervals (ms)
POLL_MAIN_MATCH_MS=1500
POLL_TICKER_MS=15000
POLL_LIVESCORES_MS=9000
